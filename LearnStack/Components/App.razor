@using Microsoft.AspNetCore.Components.Web
@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["LearnStack.styles.css"]"/>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="@Assets["_content/MudBlazor/MudBlazor.min.css"]" rel="stylesheet" />
    
    <ImportMap/>
    <HeadOutlet @rendermode="@RenderModeForPage"/>
</head>

<body>
<Routes @rendermode="@RenderModeForPage"/>
<ReconnectModal/>
<script src="@Assets["_framework/blazor.web.js"]"></script>
<script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
<script src="@Assets["app.js"]"></script>

<script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>

</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [Inject]
    private PersistentComponentState ApplicationState { get; set; } = default!;

    private IComponentRenderMode? RenderModeForPage => 
        HttpContext?.GetEndpoint()?.Metadata.GetMetadata<ExcludeFromInteractiveRoutingAttribute>() is not null 
            ? null 
            : InteractiveServer;

    protected override void OnInitialized()
    {
        // App.razor is always static SSR. Persist the culture so the interactive circuit can pick it up.
        if (HttpContext is not null)
        {
            ApplicationState.RegisterOnPersisting(() =>
            {
                ApplicationState.PersistAsJson("culture", CultureInfo.CurrentUICulture.Name);
                return Task.CompletedTask;
            });
        }
    }
}

