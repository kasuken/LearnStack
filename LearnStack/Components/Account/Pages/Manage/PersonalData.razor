@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using LearnStack.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>@L["Personal data"]</PageTitle>

<div class="manage-section-header">
    <h3>@L["Personal data"]</h3>
    <p>@L["Download or delete your personal data."]</p>
</div>

<StatusMessage/>

<div class="manage-card">
    <p style="color: #475569; line-height: 1.6; margin-bottom: 16px;">@L["Your account contains personal data that you have given us. This page allows you to download or delete that data."]</p>
    <p style="color: #b91c1c; font-weight: 500; margin-bottom: 24px;">@L["Deleting this data will permanently remove your account, and this cannot be recovered."]</p>
    <div class="btn-group">
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken/>
            <button class="btn-primary" type="submit">@L["Download my data"]</button>
        </form>
        <a href="Account/Manage/DeletePersonalData" class="btn-danger">@L["Delete my account"]</a>
    </div>
</div>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }

}
